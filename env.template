# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ── Stripe ────────────────────────────────────────────────────────────────────
# Server-side only (never expose to browser)
STRIPE_SECRET_KEY=sk_live_...

# Webhook secret — get this from Stripe Dashboard → Webhooks → Signing secret
# For local dev use: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Client-side publishable key (safe to expose)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Membership subscription Price IDs (created in Stripe Dashboard → Products)
# Create a product "Membership" with 2 recurring prices, copy the price IDs here
NEXT_PUBLIC_STRIPE_MONTHLY_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_YEARLY_PRICE_ID=price_...

# NOTE: Event and program payments use DYNAMIC pricing — no Price ID needed.
#       The amount is taken from the event/program price field in the database.
#       Just make sure STRIPE_SECRET_KEY is set and the event has a price > 0.
