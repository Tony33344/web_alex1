# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ── Stripe ────────────────────────────────────────────────────────────────────
# Server-side only (never expose to browser)
STRIPE_SECRET_KEY=sk_test_...          # Get from Stripe Dashboard → Developers → API keys (test mode)
STRIPE_WEBHOOK_SECRET=whsec_...        # For local dev: stripe listen --forward-to localhost:3000/api/stripe/webhook

# Client-side publishable key (safe to expose)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...  # Get from Stripe Dashboard → Developers → API keys (test mode)

# OPTIONAL: Membership subscription Price IDs (if you want pre-configured Stripe Prices)
# If left blank, the system uses DYNAMIC pricing from Admin → Membership
NEXT_PUBLIC_STRIPE_MONTHLY_PRICE_ID=
NEXT_PUBLIC_STRIPE_YEARLY_PRICE_ID=

# NOTE: All payments (events, programs, membership) now use DYNAMIC pricing from the database.
#       You only need STRIPE_SECRET_KEY and NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY to start.
#       Change prices in Admin panel — no Stripe dashboard configuration needed.

# ── Email (Hostpoint.ch) ──────────────────────────────────────────────────────
# 1. Create email account in Hostpoint control panel
# 2. Use these SMTP settings:
SMTP_HOST=mail.hostpoint.ch
SMTP_PORT=587
SMTP_USER=support@infinityroleteachers.com
SMTP_PASS=your_password_here
SMTP_FROM=Infinity Role Teachers <support@infinityroleteachers.com>
